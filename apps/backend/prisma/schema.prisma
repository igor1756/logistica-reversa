generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
  TECNICO
}

model Usuario {
  id         String   @id @default(uuid())
  matricula  String   @unique
  nome       String
  setor      String?
  tipo       UserRole @default(USER)
  senhaHash  String
  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}